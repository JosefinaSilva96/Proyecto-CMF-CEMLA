)
cat("df_es (con RM para g=2013):\n")
cat("  Obs:     ", nrow(df_es), "\n")
cat("  Regiones:", n_distinct(df_es$regid), "\n")
# ── Función estimación por cohorte ────────────────────────────────────────────
run_es_cohort <- function(cohort_year, data) {
data |>
filter(year_court == cohort_year |
year_court == 0           |
year_court > cohort_year) |>
filter(!is.na(event_time_w) | year_court != cohort_year) |>
mutate(
event_time_w = replace_na(event_time_w, -1L),
event_time_f = relevel(factor(event_time_w), ref = "-1")
) |>
feols(
lnewcred_w ~ i(event_time_f, lrcases, ref = "-1") |
bankfirm_id + IDS^year + IDB^year,
data    = _,
cluster = ~IDR_fixed + IDS
)
}
# ── Estimar los 3 modelos ─────────────────────────────────────────────────────
es_2013 <- run_es_cohort(2013, df_es)
es_2014 <- run_es_cohort(2014, df_es)
es_2017 <- run_es_cohort(2017, df_es)
# ── Extraer coeficientes ──────────────────────────────────────────────────────
tidy_es <- function(model, label) {
broom::tidy(model, conf.int = TRUE) |>
filter(str_detect(term, "event_time_f")) |>
mutate(
event_time = as.integer(str_extract(term, "-?\\d+")),
cohort     = label
) |>
select(event_time, estimate, conf.low, conf.high, p.value, cohort) |>
bind_rows(
tibble(event_time = -1L, estimate = 0,
conf.low = 0, conf.high = 0,
p.value  = 1, cohort = label)
) |>
arrange(event_time) |>
mutate(
sig_lab = factor(if_else(p.value < 0.05,
"Significant (p<0.05)",
"Insignificant"),
levels = c("Significant (p<0.05)", "Insignificant"))
)
}
es_data <- bind_rows(
tidy_es(es_2013, "Panel A: Santiago Court (g = 2013)"),
tidy_es(es_2014, "Panel B: Valdivia Court (g = 2014)"),
tidy_es(es_2017, "Panel C: Antofagasta Court (g = 2017)")
) |>
mutate(cohort = factor(cohort, levels = c(
"Panel A: Santiago Court (g = 2013)",
"Panel B: Valdivia Court (g = 2014)",
"Panel C: Antofagasta Court (g = 2017)"
)))
# ── Plot estilo paper ─────────────────────────────────────────────────────────
ggplot(es_data, aes(event_time, estimate)) +
annotate("rect", xmin = -0.5, xmax = Inf,
ymin = -Inf, ymax = Inf,
fill = "grey90", alpha = 0.3) +
geom_hline(yintercept = 0,    colour = "black", linewidth = 0.4) +
geom_vline(xintercept = -0.5, colour = "black",
linewidth  = 0.4,  linetype = "dashed") +
geom_ribbon(aes(ymin = conf.low, ymax = conf.high),
fill = "grey70", alpha = 0.35, colour = NA) +
geom_line(colour = "black", linewidth = 0.6) +
geom_point(aes(fill = sig_lab),
shape = 21, size = 2.8,
colour = "black", stroke = 0.7) +
scale_fill_manual(
values = c("Significant (p<0.05)" = col_high,
"Insignificant"        = "white"),
name   = NULL
) +
scale_x_continuous(breaks = -3:6) +
scale_y_continuous(labels = number_format(accuracy = 0.01)) +
facet_wrap(~cohort, ncol = 3, scales = "fixed") +
labs(
title    = "Dynamic Effects of Environmental Enforcement on Credit",
subtitle = "Interaction: log SMA cases × years relative to court introduction",
x        = "Years relative to court introduction (τ)",
y        = "Coefficient (log average credit balance)",
caption  = paste(
"Notes: Each panel estimates a separate TWFE event study for one treatment cohort,",
"using not-yet-treated and never-treated units as controls.",
"Panel A includes the Metropolitan Region.",
"Reference period τ = −1. Shaded area = 95% CI.",
"Filled markers = significant at 5%.",
"FE: bank×firm, sector×year, bank×year.",
"SE clustered by region × sector."
)
) +
theme_minimal(base_size = 11) +
theme(
plot.title       = element_text(face = "bold", size = 13, hjust = 0),
plot.subtitle    = element_text(colour = "grey40", size = 10, hjust = 0),
plot.caption     = element_text(colour = "grey50", size = 8,
hjust = 0, margin = margin(t = 8)),
strip.text       = element_text(face = "bold", size = 10, hjust = 0,
margin = margin(b = 4)),
strip.background = element_blank(),
axis.title       = element_text(size = 10),
axis.text        = element_text(size = 9),
axis.line        = element_line(colour = "black", linewidth = 0.3),
panel.grid.major.x = element_blank(),
panel.grid.minor   = element_blank(),
panel.grid.major.y = element_line(colour = "grey90", linewidth = 0.3),
panel.border     = element_rect(colour = "grey80", fill = NA,
linewidth = 0.4),
legend.position  = "bottom",
legend.text      = element_text(size = 9),
panel.spacing    = unit(1.2, "lines")
)
library(rvest)
library(httr)
# ── Función scraper para el 2do Tribunal (Santiago) ───────────────────────────
# Ya vimos la estructura: tabla con columnas ROL y ANTECEDENTES
scrape_santiago <- function() {
url  <- "https://tribunalambiental.cl/sentencias-e-informes/sentencias/"
page <- read_html(url)
rows <- page |> html_elements("table tr") |> keep(~length(html_elements(.x, "td")) > 0)
map_dfr(rows, function(row) {
cells <- html_elements(row, "td")
if (length(cells) < 2) return(NULL)
rol        <- html_text2(cells[1]) |> str_trim()
texto      <- html_text2(cells[2])
# Extraer campos del texto
region     <- str_extract(texto, "(?<=Región:\\s{0,5})[^\\.\\n]+")
fecha      <- str_extract(texto, "(?<=Fecha del fallo:\\s{0,5})[0-9\\-]+")
resuelve   <- str_extract(texto, "(?<=Resuelve:\\s{0,5})[^\\.\\n]+")
tibble(rol, region, fecha_fallo = fecha, resuelve,
tribunal = "Santiago", cohort = 2013)
})
}
# ── Función scraper para el 3er Tribunal (Valdivia) ───────────────────────────
scrape_valdivia <- function() {
url  <- "https://www.3ta.cl/sentencias-e-informes/sentencias/"
page <- tryCatch(read_html(url), error = function(e) NULL)
if (is.null(page)) {
message("Valdivia: no se pudo acceder — intentar manualmente")
return(NULL)
}
rows <- page |> html_elements("table tr") |> keep(~length(html_elements(.x, "td")) > 0)
map_dfr(rows, function(row) {
cells <- html_elements(row, "td")
if (length(cells) < 2) return(NULL)
rol      <- html_text2(cells[1]) |> str_trim()
texto    <- html_text2(cells[2])
region   <- str_extract(texto, "(?<=Región:\\s{0,5})[^\\.\\n]+")
fecha    <- str_extract(texto, "(?<=Fecha del fallo:\\s{0,5})[0-9\\-]+")
resuelve <- str_extract(texto, "(?<=Resuelve:\\s{0,5})[^\\.\\n]+")
tibble(rol, region, fecha_fallo = fecha, resuelve,
tribunal = "Valdivia", cohort = 2014)
})
}
# ── Función scraper para el 1er Tribunal (Antofagasta) ────────────────────────
scrape_antofagasta <- function() {
url  <- "https://www.1ta.cl/sentencias-e-informes/sentencias/"
page <- tryCatch(read_html(url), error = function(e) NULL)
if (is.null(page)) {
message("Antofagasta: no se pudo acceder — intentar manualmente")
return(NULL)
}
rows <- page |> html_elements("table tr") |> keep(~length(html_elements(.x, "td")) > 0)
map_dfr(rows, function(row) {
cells <- html_elements(row, "td")
if (length(cells) < 2) return(NULL)
rol      <- html_text2(cells[1]) |> str_trim()
texto    <- html_text2(cells[2])
region   <- str_extract(texto, "(?<=Región:\\s{0,5})[^\\.\\n]+")
fecha    <- str_extract(texto, "(?<=Fecha del fallo:\\s{0,5})[0-9\\-]+")
resuelve <- str_extract(texto, "(?<=Resuelve:\\s{0,5})[^\\.\\n]+")
tibble(rol, region, fecha_fallo = fecha, resuelve,
tribunal = "Antofagasta", cohort = 2017)
})
}
# ── Correr los tres scrapers ──────────────────────────────────────────────────
sent_santiago    <- scrape_santiago()
sent_valdivia    <- scrape_valdivia()
sent_antofagasta <- scrape_antofagasta()
# ── Combinar ──────────────────────────────────────────────────────────────────
sentencias <- bind_rows(
sent_santiago,
sent_valdivia,
sent_antofagasta
) |>
mutate(
# Parsear fecha
fecha_fallo = dmy(fecha_fallo),
year        = year(fecha_fallo),
# Limpiar resuelve → binario
acoge = case_when(
str_detect(tolower(resuelve), "acoge parcialmente") ~ 0.5,
str_detect(tolower(resuelve), "acoge")              ~ 1,
str_detect(tolower(resuelve), "rechaza")            ~ 0,
TRUE                                                ~ NA_real_
)
) |>
filter(!is.na(fecha_fallo))
View(sent_antofagasta)
View(sent_valdivia)
View(sent_antofagasta)
View(sent_santiago)
scrape_valdivia <- function() {
url  <- "https://3ta.cl/sentencias/"
page <- read_html(url)
rows <- page |>
html_elements("table tr") |>
keep(~length(html_elements(.x, "td")) >= 4)
map_dfr(rows, function(row) {
cells <- html_elements(row, "td")
if (length(cells) < 4) return(NULL)
n_sent   <- html_text2(cells[1]) |> str_trim()
rol      <- html_text2(cells[2]) |> str_trim() |> str_extract("R[-\\s]?\\d+-\\d+")
caratula <- html_text2(cells[3])
fecha    <- html_text2(cells[4]) |> str_trim()
materia  <- if (length(cells) >= 6) html_text2(cells[6]) |> str_trim() else NA_character_
# Extraer resultado del texto de la carátula
resuelve <- case_when(
str_detect(tolower(caratula), "acoge parcialmente") ~ "acoge parcialmente",
str_detect(tolower(caratula), "acoge")              ~ "acoge",
str_detect(tolower(caratula), "rechaza")            ~ "rechaza",
str_detect(tolower(caratula), "aprueba")            ~ "aprueba",
TRUE                                                ~ NA_character_
)
tibble(
n_sent, rol, caratula, fecha_raw = fecha,
resuelve, materia,
tribunal = "Valdivia", cohort = 2014
)
}) |>
filter(!is.na(rol)) |>
mutate(
# Parsear fecha en español: "11 de marzo de 2026"
fecha_fallo = dmy(str_replace_all(fecha_raw,
c("enero"="1","febrero"="2","marzo"="3",
"abril"="4","mayo"="5","junio"="6",
"julio"="7","agosto"="8","septiembre"="9",
"octubre"="10","noviembre"="11","diciembre"="12",
" de " = "/"))),
year = year(fecha_fallo),
acoge = case_when(
resuelve == "acoge parcialmente" ~ 0.5,
resuelve == "acoge"              ~ 1,
resuelve == "rechaza"            ~ 0,
TRUE                             ~ NA_real_
)
)
}
sent_valdivia <- scrape_valdivia()
cat("Sentencias Valdivia scrapeadas:", nrow(sent_valdivia), "\n")
cat("Rango años:", paste(range(sent_valdivia$year, na.rm=TRUE), collapse="-"), "\n")
cat("\nDistribución por año:\n")
sent_valdivia |> count(year) |> print()
cat("\nDistribución resuelve:\n")
View(sent_valdivia)
# ── Diagnóstico sentencias disponibles ────────────────────────────────────────
sentencias_disponibles <- bind_rows(
sent_santiago  |> mutate(tribunal = "Santiago",  cohort = 2013),
sent_valdivia  |> mutate(tribunal = "Valdivia",  cohort = 2014)
)
sentencias_disponibles <- bind_rows(
sent_santiago |>
mutate(
tribunal    = "Santiago",
cohort      = 2013,
fecha_fallo = dmy(fecha_fallo)  # convertir character a date
),
sent_valdivia |>
mutate(
tribunal = "Valdivia",
cohort   = 2014
)
) |>
mutate(year = year(fecha_fallo))
cat("=== Sentencias disponibles ===\n")
sentencias_disponibles |>
group_by(tribunal) |>
summarise(
n_total   = n(),
n_acoge   = sum(acoge == 1,   na.rm = TRUE),
n_parcial = sum(acoge == 0.5, na.rm = TRUE),
n_rechaza = sum(acoge == 0,   na.rm = TRUE),
n_na      = sum(is.na(acoge)),
pct_acoge = round(100 * mean(acoge >= 0.5, na.rm = TRUE), 1),
.groups   = "drop"
) |> print()
cat("\n=== Distribución por año ===\n")
sentencias_disponibles |>
filter(!is.na(year)) |>
group_by(tribunal, year) |>
summarise(
n         = n(),
pct_acoge = round(100 * mean(acoge >= 0.5, na.rm = TRUE), 1),
.groups   = "drop"
) |>
print(n = 30)
# Ver qué tiene sent_santiago
sent_santiago |>
select(rol, resuelve, acoge) |>
head(10) |>
print()
View(sent_santiago)
names(sent_santiago)
# Ver los primeros valores de resuelve
sent_santiago |>
select(rol, region, resuelve) |>
head(10) |>
print()
# Contar cuántos tienen valor
sent_santiago |>
summarise(
n_con_resuelve = sum(!is.na(resuelve) & resuelve != ""),
n_sin_resuelve = sum(is.na(resuelve) | resuelve == ""),
ejemplo = first(resuelve[!is.na(resuelve)])
) |>
print()
# ── Fix: limpiar espacios y reconstruir acoge ──────────────────────────────────
sentencias_disponibles <- sentencias_disponibles |>
mutate(
resuelve = str_trim(tolower(resuelve)),
acoge = case_when(
str_detect(resuelve, "acoge parcialmente") ~ 0.5,
str_detect(resuelve, "acoge")              ~ 1,
str_detect(resuelve, "rechaza")            ~ 0,
str_detect(resuelve, "aprueba")            ~ 1,
TRUE                                       ~ NA_real_
)
)
# Verificar
sentencias_disponibles |>
group_by(tribunal) |>
summarise(
n_total   = n(),
n_acoge   = sum(acoge == 1,   na.rm = TRUE),
n_parcial = sum(acoge == 0.5, na.rm = TRUE),
n_rechaza = sum(acoge == 0,   na.rm = TRUE),
n_na      = sum(is.na(acoge)),
pct_acoge = round(100 * mean(acoge >= 0.5, na.rm = TRUE), 1),
.groups   = "drop"
) |> print()
cat("\n=== Variación por año ===\n")
sentencias_disponibles |>
filter(!is.na(year), year >= 2013, year <= 2024) |>
group_by(tribunal, year) |>
summarise(
n         = n(),
pct_acoge = round(100 * mean(acoge >= 0.5, na.rm = TRUE), 1),
.groups   = "drop"
) |>
print(n = 30)
View(sent_valdivia)
# ── Construir variable de credibilidad judicial — Santiago ─────────────────────
credibilidad_stgo <- sentencias_disponibles |>
filter(tribunal == "Santiago", year >= 2013, year <= 2024) |>
group_by(year) |>
summarise(
n_sent       = n(),
pct_acoge    = mean(acoge >= 0.5, na.rm = TRUE),
cum_sent     = cumsum(n())[n()],   # sentencias acumuladas al año
.groups      = "drop"
) |>
mutate(
# Lag de un año — los bancos reaccionan al historial pasado
lag_pct_acoge = lag(pct_acoge),
lag_n_sent    = lag(n_sent),
# Variable de credibilidad: más sentencias + más acogidas = más creíble
credibilidad  = lag_pct_acoge * log1p(lag_n_sent)
)
cat("Variable de credibilidad judicial (Santiago):\n")
credibilidad_stgo |> print()
# ── Merge con el panel de crédito ─────────────────────────────────────────────
# Solo para las regiones del tribunal de Santiago (cohort 2013)
df_cred <- df |>
left_join(
credibilidad_stgo |> select(year, pct_acoge, credibilidad, n_sent),
by = "year"
) |>
mutate(
# Solo aplica a regiones de Santiago
credibilidad = if_else(year_court == 2013, credibilidad, NA_real_),
pct_acoge    = if_else(year_court == 2013, pct_acoge,    NA_real_)
)
cat("\nMerge exitoso — obs con credibilidad:\n")
df_cred |>
filter(year_court == 2013) |>
count(!is.na(credibilidad)) |>
print()
# ── Event study: event_time × credibilidad ────────────────────────────────────
df_es_cred <- df_cred |>
filter(year_court == 2013 | year_court == 0) |>  # Santiago + never-treated
mutate(
IDR_fixed    = as.integer(factor(regid)),
event_time   = if_else(year_court > 0,
as.integer(year - year_court),
NA_integer_),
event_time_w = case_when(
event_time < -3 ~ -3L,
event_time >  6 ~  6L,
TRUE            ~ event_time
),
event_time_w = replace_na(event_time_w, -1L),
event_time_f = relevel(factor(event_time_w), ref = "-1"),
# Centrar credibilidad para interpretación ATT
credibilidad_dm = credibilidad - mean(credibilidad, na.rm = TRUE),
# Para never-treated, credibilidad = 0 (no tienen tribunal)
credibilidad_dm = replace_na(credibilidad_dm, 0)
)
# Modelo 1: interacción con lrcases (replicación)
es_stgo_cases <- feols(
lnewcred_w ~ i(event_time_f, lrcases, ref = "-1") |
bankfirm_id + IDS^year + IDB^year,
data    = df_es_cred,
cluster = ~IDR_fixed + IDS
)
# Modelo 2: interacción con credibilidad (contribución nueva)
es_stgo_cred <- feols(
lnewcred_w ~ i(event_time_f, credibilidad_dm, ref = "-1") |
bankfirm_id + IDS^year + IDB^year,
data    = df_es_cred,
cluster = ~IDR_fixed + IDS
)
# Modelo 2: interacción con credibilidad (contribución nueva)
es_stgo_cred <- feols(
lnewcred_w ~ i(event_time_f, credibilidad_dm, ref = "-1") |
bankfirm_id + IDB^year,   # sin IDS^year
data    = df_es_cred,
cluster = ~IDR_fixed + IDS
)
# Modelo 3: ambas interacciones juntas
es_stgo_both <- feols(
lnewcred_w ~ i(event_time_f, lrcases,         ref = "-1") +
i(event_time_f, credibilidad_dm, ref = "-1") |
bankfirm_id + IDS^year + IDB^year,
data    = df_es_cred,
cluster = ~IDR_fixed + IDS
)
cat("Modelos estimados. Comparando R2:\n")
cat("  Cases only:    ", r2(es_stgo_cases)["r2"], "\n")
cat("  Credibilidad:  ", r2(es_stgo_cred)["r2"],  "\n")
cat("  Ambas:         ", r2(es_stgo_both)["r2"],  "\n")
es_stgo_cred2 <- feols(
lnewcred_w ~ i(event_time_f, lrcases, ref = "-1") +
i(event_time_f, I(lrcases * credibilidad_dm), ref = "-1") |
bankfirm_id + IDS^year + IDB^year,
data    = df_es_cred,
cluster = ~IDR_fixed + IDS
)
# Modelo 3: ambas interacciones juntas
es_stgo_both <- feols(
lnewcred_w ~ i(event_time_f, lrcases,         ref = "-1") +
i(event_time_f, credibilidad_dm, ref = "-1") |
bankfirm_id + IDS^year + IDB^year,
data    = df_es_cred,
cluster = ~IDR_fixed + IDS
)
cat("Modelos estimados. Comparando R2:\n")
cat("  Cases only:    ", r2(es_stgo_cases)["r2"], "\n")
cat("  Credibilidad:  ", r2(es_stgo_cred2)["r2"],  "\n")
cat("  Ambas:         ", r2(es_stgo_both)["r2"],  "\n")
# Gráfico de credibilidad judicial por año
ggplot(credibilidad_stgo, aes(year, pct_acoge)) +
geom_col(aes(fill = pct_acoge > 0.5), alpha = 0.85) +
geom_line(aes(y = credibilidad / max(credibilidad, na.rm=TRUE)),
colour = col_high, linewidth = 1) +
geom_vline(xintercept = 2013.5, linetype = "dashed",
colour = col_court) +
scale_fill_manual(values = c("FALSE" = col_low, "TRUE" = col_high)) +
scale_y_continuous(
labels = percent_format(),
sec.axis = sec_axis(~. * max(credibilidad_stgo$credibilidad,
na.rm = TRUE),
name = "Credibility index")
) +
scale_x_continuous(breaks = 2013:2024) +
labs(
title    = "Judicial Credibility of Santiago Environmental Court",
subtitle = "Bar = % sentences upheld | Line = credibility index (lag)",
x = NULL, y = "% sentences upheld",
fill = "Majority upheld"
) +
theme(legend.position = "bottom")
# ── Preparar datos ─────────────────────────────────────────────────────────────
df_km <- df |>
mutate(
IDR_fixed    = as.integer(factor(regid)),
event_time   = if_else(year_court > 0,
as.integer(year - year_court),
NA_integer_),
event_time_w = case_when(
event_time < -3 ~ -3L,
event_time >  6 ~  6L,
TRUE            ~ event_time
),
event_time_w = replace_na(event_time_w, -1L),
event_time_f = relevel(factor(event_time_w), ref = "-1"),
# Centrar score_share para interpretación ATT
score_dm     = score_share - mean(score_share, na.rm = TRUE)
)
# ── Estimar event study con score_share como exposición ───────────────────────
# Identificación: dentro del mismo banco-año y sector-año,
# las firmas con mayor score ENCORE reciben menos crédito post-tribunal?
es_km <- feols(
lnewcred_w ~ i(event_time_f, score_dm, ref = "-1") |
bankfirm_id + IDB^year + IDS^year,
data    = df_km,
cluster = ~IDR_fixed + IDS
)
summary(es_km)
